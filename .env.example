# Required: Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Telegram API credentials for large file uploads (up to 2 GB)
# Get these free at https://my.telegram.org → API development tools
TG_API_ID=
TG_API_HASH=

# Optional: FastAPI backend URL (default: http://localhost:8000/api/v1)
# API_BASE_URL=http://localhost:8000/api/v1

# Optional: Performance tuning
# MAX_EXTRACTIONS=6       # Max concurrent yt-dlp extractions (API server)
# MAX_DOWNLOADS=4         # Max concurrent downloads (API server)
# CACHE_TTL=300           # Extraction cache TTL in seconds (API server)
# RATE_LIMIT_REQ=30       # Rate limit: requests per window per IP (API server)
# RATE_LIMIT_WIN=60       # Rate limit: window in seconds (API server)
# WORKERS=1               # Uvicorn worker processes (API server)
# BOT_WORKERS=4           # Max concurrent bot downloads
# FRAGMENT_THREADS=8      # yt-dlp concurrent fragment downloads
# CAPTION_DEFAULT=true    # Show captions by default
