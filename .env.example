# Optional: Netscape cookies — export to cookies.txt in project root, then use docker-compose.override.yml
# to mount `./cookies.txt:/app/cookies.txt:ro` for api and bot. Do not commit cookies.txt.

# Required: Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Telegram API credentials for large file uploads (up to 2 GB)
# Get these free at https://my.telegram.org → API development tools
TG_API_ID=
TG_API_HASH=

# Optional: FastAPI backend URL (default: http://localhost:8000/api/v1, or in Docker Compose
# http://api:8000/api/v1 unless you override below). Set when the Telegram bot must reach the API
# over a public hostname instead of the internal service name.
# API_BASE_URL=http://localhost:8000/api/v1

# Optional: Public site URL (no trailing slash). Set when using the Caddy service / HTTPS so
# OpenAPI/Swagger "Try it out" matches your real host.
# PUBLIC_URL=https://anygrab.lwinminkhant.pro

# Optional: Comma-separated Host header values (production). Match your public hostname.
# localhost, 127.0.0.1, [::1], and api are always allowed (Docker healthchecks & internal Compose).
# TRUSTED_HOSTS=anygrab.lwinminkhant.pro

# Optional: CORS — for the web UI on your domain (same-origin fetches usually work without this; set if you call the API from another site).
# CORS_ORIGINS=https://anygrab.lwinminkhant.pro
# CORS_ORIGINS=*

# Optional: Performance tuning
# MAX_EXTRACTIONS=6       # Max concurrent yt-dlp extractions (API server)
# MAX_DOWNLOADS=4         # Max concurrent downloads (API server)
# CACHE_TTL=300           # Extraction cache TTL in seconds (API server)
# RATE_LIMIT_REQ=30       # Rate limit: requests per window per IP (API server)
# RATE_LIMIT_WIN=60       # Rate limit: window in seconds (API server)
# WORKERS=1               # Uvicorn worker processes (API server)
# BOT_WORKERS=4           # Max concurrent bot downloads
# FRAGMENT_THREADS=8      # yt-dlp concurrent fragment downloads
# CAPTION_DEFAULT=true    # Show captions by default
